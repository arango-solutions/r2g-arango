# R2G-ETL Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ArangoDB (Docker)
ARANGO_IMAGE=arangodb:3.12
ARANGO_CONTAINER=r2g-test-arangodb
ARANGO_PORT=8540
ARANGO_ROOT_PASSWORD=changeme
ARANGO_ENDPOINT=http://localhost:8540
ARANGO_DB=r2g_test
ARANGO_USER=root
ARANGO_PASSWORD=changeme

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=your_pg_user
PG_PASSWORD=
PG_DATABASE=your_database
PG_CONN=postgresql://your_pg_user@localhost:5432/your_database
