# R2G-ETL Environment Configuration
# Copy to .env and edit values. The CLI auto-loads .env from the working directory.
# CLI flags override these values when both are provided.

# PostgreSQL
PG_CONN=postgresql://user:password@localhost:5432/mydb

# ArangoDB
ARANGO_ENDPOINT=http://localhost:8529
ARANGO_DB=_system
ARANGO_USER=root
ARANGO_PASSWORD=
