# R2G-ETL Environment Configuration
# Copy to .env and edit values. The CLI auto-loads .env from the working directory.
# CLI flags override these values when both are provided.

# PostgreSQL
PG_CONN=postgresql://user:password@localhost:5432/mydb

# ArangoDB
ARANGO_ENDPOINT=http://localhost:8529
ARANGO_DB=_system
ARANGO_USER=root
ARANGO_PASSWORD=

# --- Optional security settings ---

# Fernet key for encrypting credentials in the catalog. When unset, r2g uses
# (or creates) ~/.r2g/secret.key. Generate one with: r2g secrets init
#R2G_SECRET_KEY=

# Bearer token required for /api/* when the Studio UI binds to a non-loopback
# address. Auto-generated and printed at startup if unset.
#R2G_API_TOKEN=

# Comma-separated list of allowed CORS origins for the Studio UI.
# Default: same-origin only.
#R2G_CORS_ORIGINS=

# Confine CSV sources to a trusted directory tree. When set, any CSV source
# directory must resolve to a location inside it (symlinks and .. resolved
# first). Recommended when exposing the UI/MCP server on a shared host.
# Default: unset (any local path allowed).
#R2G_CSV_BASE_DIR=

# The MCP SSE transport reuses R2G_API_TOKEN. Binding it to a non-loopback
# address requires a Bearer token (auto-generated and printed if unset).
